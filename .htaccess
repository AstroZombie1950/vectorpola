# ===== Базовая защита =====
Options -Indexes

# Закрываем конфиг с доступами от прямого обращения
<Files "config.php">
	Order Allow,Deny
	Deny from all
</Files>

# ===== HTTPS + склейка www =====
# >>> ТЕКУЩАЯ КОНФИГУРАЦИЯ: ТЕСТ-ХОСТ (без SSL) <
<IfModule mod_rewrite.c>
	RewriteEngine On

	# --- ПРОД (vectorpola.ru): раскомментировать этот блок ---
	# RewriteCond %{HTTP:X-Forwarded-Proto} !https
	# RewriteCond %{HTTPS} off
	# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
	# RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
	# RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

	# --- ТЕСТ (без HTTPS): закомментировать на проде ---
	RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
	RewriteRule ^ http://%1%{REQUEST_URI} [L,R=301]

	# Закрываем хранилище данных от прямого доступа
	RewriteRule ^data/ - [F,L]
</IfModule>

# ===== Gzip-сжатие текстовых ресурсов =====
<IfModule mod_deflate.c>
	AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml \
		application/javascript application/json application/xml image/svg+xml
</IfModule>

# ===== Кэширование статики в браузере =====
<IfModule mod_expires.c>
	ExpiresActive On
	ExpiresByType text/css              "access plus 30 days"
	ExpiresByType application/javascript "access plus 30 days"
	ExpiresByType image/webp            "access plus 180 days"
	ExpiresByType image/jpeg            "access plus 180 days"
	ExpiresByType image/png             "access plus 180 days"
	ExpiresByType image/svg+xml         "access plus 180 days"
	ExpiresByType image/x-icon          "access plus 365 days"
	ExpiresByType font/woff2            "access plus 365 days"
</IfModule>

# ===== Роутинг каталога =====
<IfModule mod_rewrite.c>
	RewriteEngine On

	# Карточка товара: /catalog/{категория}/{slug}/
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule ^catalog/([a-z0-9-]+)/([a-z0-9-]+)/?$ product.php?cat=$1&slug=$2 [L,QSA]

	# Страница категории: /catalog/{категория}/
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule ^catalog/([a-z0-9-]+)/?$ category.php?cat=$1 [L,QSA]

	# Индекс каталога: /catalog/
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule ^catalog/?$ catalog-index.php [L,QSA]

	# Корзина: /cart/
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule ^cart/?$ cart.php [L,QSA]

	# Поиск: /search/
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule ^search/?$ search.php [L,QSA]

	# /sitemap.xml → динамический PHP
	RewriteRule ^sitemap\.xml$ sitemap.php [L]
</IfModule>